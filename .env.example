# AI融合UI自动化测试框架 - 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ========== AI服务配置 ==========
# 智谱AI API密钥 (必填，用于AI功能)
ZHIPU_API_KEY=your_zhipu_api_key_here

# 可选：OpenAI API密钥 (如果使用OpenAI模型)
OPENAI_API_KEY=your_openai_api_key_here

# ========== 测试环境配置 ==========
# 默认测试环境 (test/staging/production)
TEST_ENV=test

# ========== 浏览器配置 ==========
# 默认浏览器 (chromium/firefox/webkit/edge)
BROWSER_TYPE=chromium

# 是否使用有头模式 (true/false)
HEADED=false

# 慢动作延迟 (毫秒，用于调试)
SLOW_MO=0

# 默认超时时间 (毫秒)
DEFAULT_TIMEOUT=30000

# ========== AI功能开关 ==========
# 启用AI测试用例生成
AI_TEST_GENERATION=true

# 启用AI失败分析
AI_FAILURE_ANALYSIS=true

# 启用AI自愈能力
AI_SELF_HEALING=true

# ========== 报告配置 ==========
# Allure报告标题
ALLURE_REPORT_NAME=UI自动化测试报告

# ========== 日志配置 ==========
# 日志级别 (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO
